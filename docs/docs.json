{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Browser Use Cloud",
  "colors": {
    "primary": "#FE750E",
    "light": "#FE750E",
    "dark": "#FE750E"
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#09090B"
    }
  },
  "favicon": "/favicon.ico",
  "appearance": {
    "default": "dark"
  },
  "contextual": {
    "options": ["copy", "view"]
  },
  "fonts": {
    "family": "Geist"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "errors": {
    "404": {
      "redirect": true
    }
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["javascript", "curl", "python"],
      "required": true
    }
  },
  "navigation": {
    "versions": [
      {
        "version": "Cloud",
        "tabs": [
          {
            "tab": "Docs",
            "groups": [
              {
                "group": "Get Started",
                "pages": ["introduction", "llm-quickstart", "new-features/api-v3", "pricing"]
              },
              {
                "group": "Guides",
                "pages": [
                  "guides/overview",
                  "guides/tasks",
                  "guides/sessions",
                  "guides/browser-api",
                  "guides/proxies-and-stealth",
                  "guides/skills",
                  "guides/authentication",
                  "guides/mcp-server",
                  "guides/webhooks"
                ]
              },
              {
                "group": "Resources",
                "pages": [
                  {
                    "group": "Tips",
                    "pages": [
                      {
                        "group": "Authentication",
                        "pages": [
                          "tips/authentication/profiles-and-secrets",
                          "tips/authentication/1password-2fa",
                          "tips/authentication/social-media"
                        ]
                      },
                      {
                        "group": "Live View",
                        "pages": [
                          "tips/live-view/iframe-embed",
                          "tips/live-view/human-takeover"
                        ]
                      },
                      {
                        "group": "Parallel",
                        "pages": [
                          "tips/parallel/concurrent-extraction",
                          "tips/parallel/shared-config"
                        ]
                      },
                      {
                        "group": "Data",
                        "pages": [
                          "tips/data/structured-output",
                          "tips/data/file-downloads",
                          "tips/data/geo-scraping",
                          "tips/data/streaming"
                        ]
                      },
                      {
                        "group": "Integrations",
                        "pages": [
                          "tips/integrations/playwright",
                          "tips/integrations/n8n"
                        ]
                      }
                    ]
                  },
                  "faq"
                ]
              }
            ]
          },
          {
            "tab": "API Reference",
            "groups": [
              {
                "group": "API v2 (Stable)",
                "openapi": {
                  "source": "openapi/v2.json",
                  "directory": "api-v2"
                }
              },
              {
                "group": "BU Agent API (Experimental)",
                "openapi": {
                  "source": "openapi/v3.json",
                  "directory": "api-v3"
                }
              }
            ]
          }
        ]
      },
      {
        "version": "Open Source",
        "groups": [
          {
            "group": "Open Source",
            "pages": ["open-source"]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      { "label": "Status", "href": "https://status.browser-use.com" }
    ],
    "primary": {
      "type": "button",
      "label": "Cloud Dashboard",
      "href": "https://cloud.browser-use.com"
